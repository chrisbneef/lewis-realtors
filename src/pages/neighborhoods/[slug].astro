---
import Base from "../../layouts/Base.astro";
import SectionHead from "../../components/SectionHead.astro";
import MarketReportForm from "../../components/MarketReportForm.astro";
import TrendChart from "../../components/TrendChart.astro";
import site from "../../data/site.json";
import neighborhoods from "../../data/neighborhoods.json";
import market from "../../data/market.json";
import marketHistory from "../../data/market-history.json";
import boundaries from "../../data/neighborhood-boundaries.json";
import services from "../../data/services.json";
import faq from "../../data/faq.json";
import { priceLabel } from "../../lib/market.js";
import { realEstateAgent, placeSchema, faqSchema, breadcrumb } from "../../lib/schema.js";

export function getStaticPaths() {
  return neighborhoods.map((hood) => ({
    params: { slug: hood.slug },
    props: { hood },
  }));
}

const { hood } = Astro.props;
const service = services.find((s) => s.slug === hood.serviceSlug);

const jsonLd = [
  realEstateAgent(),
  placeSchema(hood),
  breadcrumb([
    { name: "Home", path: "/" },
    { name: "Neighborhoods", path: "/#neighborhoods" },
    { name: hood.name, path: `/neighborhoods/${hood.slug}` },
  ]),
];
if (hood.complete) jsonLd.push(faqSchema(faq));

// Official boundary (Oregon Metro / Clackamas County) drives the map for every
// neighborhood - simplified ring for display, plus bbox to frame the view.
const bound = boundaries.neighborhoods[hood.slug] ?? null;
const mapData = bound ? JSON.stringify({ display: bound.display, bbox: bound.bbox }) : null;

// Live listing data. `publishable` is true once a neighborhood (backed by an
// official boundary) clears the minimum-listings threshold.
const city = market.cityData;
const nb = market.neighborhoods?.[hood.slug] ?? null;
const showNeighborhood = nb?.publishable === true;
const range = priceLabel(hood.slug);

const money = (n) => (n == null ? null : `$${Math.round(n).toLocaleString()}`);
// Chart source: prefer this neighborhood's own accumulated monthly history once
// enough months exist; until then, fall back to the city-wide RentCast trend.
// (A real per-neighborhood price history has to be banked over time - RentCast
// only provides ZIP-level history - so this auto-upgrades as snapshots pile up.)
const MIN_TREND_MONTHS = 5;
const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const ymLabel = (ym) => { const [y, m] = ym.split("-"); return `${MONTHS[+m - 1]} ${y.slice(2)}`; };
const nbHistory = Object.keys(marketHistory.months || {})
  .sort()
  .map((ym) => ({ ym, v: marketHistory.months[ym].neighborhoods?.[hood.slug] }))
  .filter((x) => typeof x.v === "number");
const useNbTrend = nbHistory.length >= MIN_TREND_MONTHS;

const trend = useNbTrend
  ? nbHistory.map((x) => ({ label: ymLabel(x.ym), month: x.ym, medianAskingPrice: x.v }))
  : (city.trend ?? []);
const trendTitle = useNbTrend ? `${hood.name} median asking price` : "West Linn median asking price";
const trendCaption = useNbTrend
  ? `Median asking price for single-family and multi-family homes in ${hood.name}, from monthly snapshots.`
  : "Median asking price across all West Linn home types.";

const refreshed = new Date(market.generatedAt).toLocaleDateString("en-US", {
  month: "long", day: "numeric", year: "numeric",
});
---

<Base
  title={`${hood.name}, West Linn`}
  description={`${hood.name}, West Linn OR: ${hood.character}. ${range}. Get the monthly ${hood.name} market report from Lewis Realtors.`}
  jsonLd={jsonLd}
>
  {mapData && (
    <Fragment slot="head">
      <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin=""
      />
    </Fragment>
  )}

  <!-- Breadcrumb + hero -->
  <section class="nb-hero">
    <div class="wrap">
      <nav class="crumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span>
        <a href="/#neighborhoods">Neighborhoods</a><span>/</span>
        <span aria-current="page">{hood.name}</span>
      </nav>

      <div class="nb-hero-grid">
        <div class="nb-hero-copy" data-reveal>
          <p class="eyebrow">West Linn &middot; {hood.character}</p>
          <h1>{hood.name}</h1>
          <p class="nb-tagline">{hood.tagline}</p>
          <div class="nb-meta">
            <span class="pill pill--gold">{range}</span>
            <span class="pill pill--azure">Fits: {hood.serviceFit}</span>
            {hood.complete
              ? <span class="pill pill--gold">Report ready</span>
              : <span class="pill pill--placeholder">Report publishing soon</span>}
          </div>
        </div>
        <div class="nb-hero-aside" data-reveal style="--reveal-delay: 120ms">
          <a class="btn btn--gold btn--lg" href="#nb-report">Get the report</a>
          <a class="phone-link" href={site.contact.phoneHref}>or call {site.contact.phone}</a>
        </div>
      </div>

      <figure class:list={["nb-banner", { "nb-banner--placeholder": !hood.image }]} data-reveal style="--reveal-delay: 180ms">
        {hood.image
          ? <img src={hood.image} alt={`${hood.name}, West Linn, Oregon`} width="1280" height="560" />
          : <span class="nb-banner-mark">{hood.name}<small>{hood.character}. Photography coming soon.</small></span>}
      </figure>
    </div>
  </section>

  <!-- Boundary map (every neighborhood; official Metro/County polygon) -->
  {mapData && (
    <section class="section--tight">
      <div class="wrap">
        <div class="nb-map card" data-reveal>
          <div id="hood-map" class="hood-map"></div>
          <script type="application/json" id="hood-map-data" set:html={mapData} is:inline></script>
          <p class="nb-map-note">Official {hood.name} boundary, via Oregon Metro / Clackamas County GIS.</p>
        </div>
      </div>
    </section>
  )}

  {hood.complete ? (
    <>
      <!-- Narrative + who it's right for -->
      <section class="section">
        <div class="wrap nb-narrative">
          <div class="nb-story" data-reveal>
            <SectionHead eyebrow="The read" title={`Who ${hood.name} is <span class="script">right for</span>.`} />
            <div class="nb-story-body stack">
              {hood.narrative.map((p) => <p>{p}</p>)}
            </div>
          </div>
          <aside class="nb-fit card" data-reveal style="--reveal-delay: 100ms">
            <h3 class="nb-fit-h">Right for</h3>
            <ul class="nb-fit-list" role="list">
              {hood.rightFor.map((r) => <li>{r}</li>)}
            </ul>
            <hr class="rule" style="margin-block: 1.6rem;" />
            <h3 class="nb-fit-h">Property types</h3>
            <ul class="nb-types" role="list">
              {hood.propertyTypes.map((t) => <li>{t}</li>)}
            </ul>
          </aside>
        </div>
      </section>

      <!-- Schools -->
      <section class="section--tight section--cream">
        <div class="wrap nb-schools" data-reveal>
          <div class="nb-schools-head">
            <p class="eyebrow">School feeders</p>
            <h2 class="nb-schools-title">{site.district}</h2>
            <p class="nb-schools-sub">The elementary, middle, and high school path for {hood.name}.</p>
          </div>
          <ol class="feeder-path" role="list">
            <li class="feeder-card"><span class="feeder-step">Elementary</span><span class="feeder-name">{hood.schools.elementary}</span></li>
            <li class="feeder-card"><span class="feeder-step">Middle</span><span class="feeder-name">{hood.schools.middle}</span></li>
            <li class="feeder-card"><span class="feeder-step">High</span><span class="feeder-name">{hood.schools.high}</span></li>
          </ol>
        </div>
      </section>

      <!-- Recommended service -->
      {service && (
        <section class="section--tight">
          <div class="wrap">
            <a class="rec card" href={`/services#${service.slug}`} data-reveal>
              <div>
                <p class="eyebrow">Recommended for {hood.name}</p>
                <h3>{service.name}</h3>
                <p class="rec-sum">{service.summary}</p>
              </div>
              <span class="link">Explore this service <span class="arrow">&rarr;</span></span>
            </a>
          </div>
        </section>
      )}
    </>
  ) : (
    <!-- The market snapshot + map are already live above; the hand-written deep
         dive (narrative, school feeders, who it fits) is still being added. -->
    <section class="section">
      <div class="wrap nb-soon" data-reveal>
        <p class="nb-soon-num">{String(hood.order).padStart(2, "0")} of {neighborhoods.length}</p>
        <h2>The full {hood.name} guide is coming.</h2>
        <p class="nb-soon-lead measure">
          The live market snapshot and boundary above update monthly. We are still adding the
          hand-written {hood.name} deep dive Bolton already has: school feeders, the streets that
          set it apart, and who it fits best. Enter your email and you will be first to get it.
        </p>
        <a class="link" href="/neighborhoods/bolton">See a finished neighborhood: Bolton <span class="arrow">&rarr;</span></a>
      </div>
    </section>
  )}

  <!-- What is on the market now (every neighborhood) -->
  <section class="section" id="on-market">
    <div class="wrap nb-stats">
      <div class="nb-stats-copy" data-reveal>
        <SectionHead eyebrow="On the market now" title={`What is for sale <span class="script">right now</span>.`} />

        {showNeighborhood ? (
          <Fragment>
            <p class="nb-stats-lead">
              {nb.activeListings} {hood.name} homes are listed for sale today. These are asking
              prices from live listings, refreshed {refreshed}.
            </p>
            <ul class="nb-figs" role="list">
              <li><span class="nb-fig-val">{nb.activeListings}</span><span class="nb-fig-label">Active listings</span></li>
              <li><span class="nb-fig-val">{money(nb.medianAskingPrice)}</span><span class="nb-fig-label">Median asking price</span></li>
              <li><span class="nb-fig-val">{nb.medianDaysOnMarket}</span><span class="nb-fig-label">Median days on market</span></li>
            </ul>
          </Fragment>
        ) : (
          <Fragment>
            <p class="nb-stats-lead">
              We publish neighborhood-level figures only once the {hood.name} boundary is confirmed
              against county parcel lines, so a home is never counted in the wrong neighborhood.
              Until then, here is the West Linn picture, refreshed {refreshed}.
            </p>
            <ul class="nb-figs" role="list">
              <li><span class="nb-fig-val">{money(city.medianAskingPrice)}</span><span class="nb-fig-label">West Linn median asking price</span></li>
              <li><span class="nb-fig-val">{city.totalListings}</span><span class="nb-fig-label">Homes on the market</span></li>
              <li><span class="nb-fig-val">{city.averageDaysOnMarket}</span><span class="nb-fig-label">Avg days on market</span></li>
            </ul>
          </Fragment>
        )}

        <p class="nb-headline-note">
          Asking prices from active single-family and multi-family listings in ZIP {market.zipCode}
          (condos, townhomes, and manufactured homes excluded). Oregon does not make closed sale
          prices public record, so Melissa pulls sold figures directly from RMLS on request.
        </p>
      </div>

      <TrendChart trend={trend} title={trendTitle} caption={trendCaption} />
    </div>
  </section>

  {showNeighborhood && nb.samples.length > 0 && (
    <section class="section--tight">
      <div class="wrap">
        <div class="comps-head" data-reveal>
          <SectionHead eyebrow="Recent activity" title={`Newest ${hood.name} listings`} />
        </div>
        <div class="comps-grid">
          {nb.samples.map((c) => (
            <div class="comp card" data-reveal>
              <span class="comp-tag">For sale</span>
              <p class="comp-addr">{c.formattedAddress}</p>
              <p class="comp-price">{money(c.price)}</p>
              <ul class="comp-meta" role="list">
                <li>{c.bedrooms} bd</li><li>{c.bathrooms} ba</li><li>{c.squareFootage?.toLocaleString()} sqft</li>
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Gated report form (every neighborhood) -->
  <section class="section section--ink" id="nb-report">
    <div class="wrap nb-form-layout">
      <div class="nb-form-copy" data-reveal>
        <SectionHead
          eyebrow="Get the report"
          title={`The ${hood.name} <span class="script">market report</span>.`}
        />
        <p class="nb-form-lead">
          One page, plain English, refreshed monthly from live listing data. Melissa is notified the
          moment you request it, so a real local answer is never far behind.
        </p>
      </div>
      <div class="nb-form" data-reveal style="--reveal-delay: 100ms">
        <MarketReportForm
          formType="market-report"
          neighborhood={hood.slug}
          neighborhoodName={hood.name}
          cta="Send my report"
        />
      </div>
    </div>
  </section>

  {mapData && (
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  )}
  {mapData && <script src="../../scripts/map.js"></script>}
</Base>

<style>
  .nb-hero { padding-block: clamp(1.5rem, 1rem + 2vw, 3rem) clamp(2rem, 1.5rem + 2vw, 3.5rem); }
  .crumb { display: flex; align-items: center; gap: 0.6rem; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 2.5rem; }
  .crumb a:hover { color: var(--gold-deep); }
  .crumb span[aria-current] { color: var(--ink); }

  .nb-hero-grid { display: grid; grid-template-columns: 1.4fr 0.6fr; gap: 2.5rem; align-items: end; }
  .nb-hero h1 { font-size: clamp(2.6rem, 1.8rem + 4vw, 5rem); margin-block: 1rem 0; }
  .nb-tagline { font-family: var(--font-display); font-size: clamp(1.3rem, 1.1rem + 1vw, 1.9rem); font-style: italic; color: var(--ink-soft); margin-top: 0.8rem; max-width: 30ch; }
  .nb-meta { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.6rem; }
  .nb-hero-aside { display: flex; flex-direction: column; align-items: flex-start; gap: 0.9rem; }

  .nb-banner {
    margin: clamp(1.5rem, 1rem + 2vw, 2.5rem) 0 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    aspect-ratio: 21 / 9;
  }
  .nb-banner img { width: 100%; height: 100%; object-fit: cover; }
  .nb-banner--placeholder {
    display: grid;
    place-items: center;
    text-align: center;
    background:
      radial-gradient(120% 120% at 100% 0%, color-mix(in srgb, var(--gold) 24%, transparent), transparent 60%),
      linear-gradient(150deg, var(--noir-soft), #2b2924 72%);
  }
  .nb-banner-mark {
    display: flex; flex-direction: column; gap: 0.5rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.4rem + 3vw, 3.6rem);
    color: color-mix(in srgb, var(--gold-bright) 90%, #fff);
  }
  .nb-banner-mark small {
    font-family: var(--font-body);
    font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--ink-onDark-soft);
  }
  @media (max-width: 700px) { .nb-banner { aspect-ratio: 16 / 10; } }
  .phone-link { font-size: 0.85rem; color: var(--ink-muted); }
  .phone-link:hover { color: var(--gold-deep); }

  .nb-map { padding: 0.7rem; overflow: hidden; }
  .hood-map { height: clamp(320px, 45vh, 520px); width: 100%; border-radius: var(--radius); background: var(--cream-deep); z-index: 0; }
  .nb-map-note { font-size: 0.72rem; color: var(--ink-muted); padding: 0.8rem 0.4rem 0.3rem; }

  .nb-narrative { display: grid; grid-template-columns: 1.5fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  .nb-story-body { --flow: 1.1rem; margin-top: 1.6rem; color: var(--ink-soft); font-size: var(--fs-lead); font-weight: 300; }
  .nb-fit { padding: 1.8rem; position: sticky; top: 122px; }
  .nb-fit-h { font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: var(--tracking-eyebrow); text-transform: uppercase; color: var(--gold-deep); margin-bottom: 1rem; }
  .nb-fit-list li { padding: 0.6rem 0 0.6rem 1.5rem; position: relative; border-bottom: 1px solid var(--line); font-size: 0.95rem; }
  .nb-fit-list li::before { content: ""; position: absolute; left: 0; top: 1.1em; width: 7px; height: 7px; border-radius: 50%; background: var(--grad-gold); }
  .nb-types { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .nb-types li { font-size: 0.74rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-soft); border: 1px solid var(--line-strong); border-radius: 100px; padding: 0.35em 0.8em; }

  .nb-schools-head { margin-bottom: 1.8rem; max-width: 60ch; }
  .nb-schools-title { font-size: clamp(1.55rem, 1.2rem + 1.3vw, 2.15rem); margin-top: 0.5rem; }
  .nb-schools-sub { color: var(--ink-soft); margin-top: 0.6rem; font-size: 0.95rem; }
  .feeder-path {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .feeder-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1.2rem 1.4rem;
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-top: 3px solid var(--azure-deep);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  /* connector arrow sits centered in the grid gap, not as a list item */
  .feeder-card:not(:last-child)::after {
    content: "\2192";
    position: absolute;
    top: 50%;
    right: -1.2rem;
    transform: translate(50%, -50%);
    color: var(--azure-deep);
    font-size: 1.15rem;
    line-height: 1;
  }
  .feeder-step { font-size: 0.64rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--azure-deep); }
  .feeder-name { font-family: var(--font-display); font-size: clamp(1.1rem, 1rem + 0.4vw, 1.35rem); line-height: 1.2; }
  @media (max-width: 640px) {
    .feeder-path { grid-template-columns: 1fr; gap: 2.2rem; }
    .feeder-card:not(:last-child)::after {
      content: "\2193";
      top: auto;
      right: auto;
      bottom: -1.1rem;
      left: 50%;
      transform: translate(-50%, 50%);
    }
  }

  .nb-stats { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: center; }
  .nb-stats-lead { color: var(--ink-soft); margin-top: 1.2rem; }
  .nb-figs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--line);
  }
  .nb-fig-val {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 1.3rem + 1.6vw, 2.6rem);
    color: var(--gold-deep);
    line-height: 1;
  }
  .nb-fig-label {
    display: block;
    margin-top: 0.55rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .nb-headline-note { font-size: 0.78rem; color: var(--ink-muted); margin-top: 1.4rem; max-width: 54ch; }
  @media (max-width: 520px) { .nb-figs { grid-template-columns: 1fr 1fr; } }

  .nb-chart { padding: 1.8rem; }
  .nb-chart-head { display: flex; align-items: center; justify-content: space-between; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 1.8rem; }
  .nb-chart-range { white-space: nowrap; }
  .bars { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.8rem; align-items: end; height: 200px; }
  /* 12-month series needs thinner columns and rotated labels to stay readable */
  .bars--year { grid-template-columns: repeat(12, 1fr); gap: 0.3rem; }
  .bars--year .bar { max-width: none; border-radius: 3px 3px 0 0; }
  .bars--year .bar-label { font-size: 0.5rem; letter-spacing: 0; writing-mode: vertical-rl; transform: rotate(180deg); }
  @media (max-width: 560px) { .bars--year .bar-label { font-size: 0.44rem; } }
  .bar-col { display: flex; flex-direction: column; align-items: center; justify-content: flex-end; gap: 0.7rem; height: 100%; }
  .bar { width: 100%; max-width: 46px; height: var(--h); background: var(--grad-azure); border-radius: 4px 4px 0 0; transition: height 0.8s var(--ease); }
  .bar-col:last-child .bar { background: var(--grad-gold); }
  .bar-label { font-size: 0.6rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-muted); }

  .comps-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .comps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  .comp { padding: 1.6rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .comp-tag { align-self: flex-start; font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--noir); background: var(--grad-gold); padding: 0.3em 0.7em; border-radius: 100px; }
  .comp-addr { font-size: 0.92rem; color: var(--ink-soft); margin-top: 0.4rem; }
  .comp-price { font-family: var(--font-display); font-size: 1.8rem; font-weight: 600; }
  .comp-meta { display: flex; gap: 1rem; font-size: 0.78rem; color: var(--ink-muted); }

  .rec { display: flex; align-items: center; justify-content: space-between; gap: 2rem; padding: 2.2rem; flex-wrap: wrap; }
  .rec h3 { font-size: 2rem; margin-top: 0.4rem; }
  .rec-sum { color: var(--ink-soft); margin-top: 0.6rem; max-width: 52ch; }

  .nb-soon { text-align: center; max-width: 60ch; margin-inline: auto; display: flex; flex-direction: column; align-items: center; gap: 1.2rem; padding-block: clamp(2rem, 1rem + 4vw, 4rem); }
  .nb-soon-num { font-size: 0.74rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold-deep); }
  .nb-soon h2 { font-size: clamp(2rem, 1.5rem + 2.5vw, 3.2rem); }
  .nb-soon-lead { color: var(--ink-soft); font-size: var(--fs-lead); font-weight: 300; }

  .nb-form-layout { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4.5rem); align-items: center; }
  .nb-form-lead { color: var(--ink-onDark-soft); margin-top: 1.4rem; }
  /* Grid/flex children default to min-width:auto, so a long neighborhood name in
     a heading forces the track wider than the viewport (mobile overflow). Let
     them shrink so the heading wraps instead. */
