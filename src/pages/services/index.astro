---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import MarketReportForm from "../../components/MarketReportForm.astro";
import services from "../../data/services.json";
import neighborhoods from "../../data/neighborhoods.json";
import { realEstateAgent } from "../../lib/schema.js";

// Neighborhoods grouped by the service each one fits, so every service links to
// the neighborhoods it serves.
const hoodsByService = (slug) => neighborhoods.filter((h) => h.serviceSlug === slug);
---

<Base
  title="Services"
  description="Buyer representation, seller and listing, luxury, first-time buyer, investor and ADU, and relocation services across West Linn, Oregon."
  jsonLd={[realEstateAgent()]}
>
  <PageHero
    crumb="Services"
    eyebrow="How we help"
    title={`Service that fits<br/>the way you <span class="script">move</span>.`}
    lead="Six ways Lewis Realtors works in West Linn, each tied to the neighborhoods it suits best. This is a starting outline. Full service detail pages follow."
  />

  <section class="section--tight">
    <div class="wrap svc-stack">
      {services.map((service) => {
        const hoods = hoodsByService(service.slug);
        return (
          <article class="svc-row" id={service.slug} data-reveal>
            <div class="svc-row-num"><span class="svc-num">{service.num}</span></div>
            <div class="svc-row-body">
              <h2>{service.name}</h2>
              <p class="svc-row-sum">{service.summary}</p>
              <p class="svc-row-for"><span>Best for</span> {service.for}</p>
              {hoods.length > 0 && (
                <div class="svc-hoods">
                  <span class="svc-hoods-label">Neighborhoods</span>
                  <ul role="list">
                    {hoods.map((h) => <li><a href={`/neighborhoods/${h.slug}`}>{h.name}</a></li>)}
                  </ul>
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="section section--ink">
    <div class="wrap form-narrow">
      <MarketReportForm formType="market-report" neighborhood="west-linn" neighborhoodName="West Linn" />
    </div>
  </section>
</Base>

<style>
  .svc-stack { display: flex; flex-direction: column; }
  .svc-row { display: grid; grid-template-columns: 80px 1fr; gap: 1.5rem; padding: clamp(2rem, 1.5rem + 2vw, 3rem) 0; border-top: 1px solid var(--line-strong); }
  .svc-row:last-child { border-bottom: 1px solid var(--line-strong); }
  .svc-num { font-family: var(--font-display); font-size: 2rem; font-weight: 600; color: var(--gold-deep); }
  .svc-row-body h2 { font-size: clamp(1.8rem, 1.4rem + 1.6vw, 2.6rem); }
  .svc-row-sum { color: var(--ink-soft); margin-top: 0.8rem; font-size: var(--fs-lead); font-weight: 300; max-width: 60ch; }
  .svc-row-for { margin-top: 1rem; font-size: 0.85rem; color: var(--ink-muted); }
  .svc-row-for span { letter-spacing: 0.12em; text-transform: uppercase; font-size: 0.7rem; color: var(--gold-deep); margin-right: 0.4rem; }
  .svc-hoods { margin-top: 1.6rem; display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem; }
  .svc-hoods-label { font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); margin-right: 0.3rem; }
  .svc-hoods ul { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .svc-hoods a { font-size: 0.74rem; letter-spacing: 0.04em; border: 1px solid var(--line-strong); border-radius: 100px; padding: 0.35em 0.85em; transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease); }
  .svc-hoods a:hover { border-color: var(--gold); color: var(--gold-deep); }
  .form-narrow { max-width: 620px; }
  @media (max-width: 600px) { .svc-row { grid-template-columns: 1fr; gap: 0.5rem; } }
</style>
