---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import NeighborhoodCard from "../components/NeighborhoodCard.astro";
import neighborhoods from "../data/neighborhoods.json";
import { realEstateAgent } from "../lib/schema.js";

const hoods = [...neighborhoods].sort((a, b) => a.order - b.order);
const ready = hoods.filter((h) => h.complete).length;
---

<Base
  title="Market Reports"
  description="Monthly West Linn neighborhood market reports: median asking price, days on market, active inventory, and the twelve-month price trend, refreshed from live listing data."
  jsonLd={[realEstateAgent()]}
>
  <PageHero
    crumb="Market Reports"
    eyebrow="The conversion centerpiece"
    title={`Every West Linn<br/>neighborhood, <span class="script">measured</span>.`}
    lead="One report per neighborhood, refreshed every month from live listing data. Pick a neighborhood to see its snapshot and request the full report."
  />

  <section class="section--tight">
    <div class="wrap">
      <p class="mr-status" data-reveal>
        <span class="pill pill--gold">{ready} live now</span>
        <span class="pill pill--placeholder">{hoods.length - ready} publishing soon</span>
      </p>
      <div class="mr-grid">
        {hoods.map((hood) => <NeighborhoodCard hood={hood} />)}
      </div>
      <p class="mr-note" data-reveal>
        Reports refresh monthly from live listing data, whose records originate from RMLS. We never
        estimate or invent figures, and where a number is not confirmed the page says so plainly.
        Oregon does not make closed sale prices public record, so Melissa pulls sold figures directly from RMLS and shares them on request.
      </p>
    </div>
  </section>
</Base>

<style>
  .mr-status { display: flex; gap: 0.7rem; margin-bottom: 2.5rem; }
  .mr-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.6rem; }
  .mr-note { margin-top: 2.5rem; font-size: 0.85rem; color: var(--ink-muted); max-width: 70ch; }
  @media (max-width: 980px) { .mr-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .mr-grid { grid-template-columns: 1fr; } }
</style>
