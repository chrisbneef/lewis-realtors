---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import MarketReportForm from "../components/MarketReportForm.astro";
import site from "../data/site.json";
import { realEstateAgent } from "../lib/schema.js";
---

<Base
  title="Contact"
  description="Talk to Melissa Shaw at Lewis Realtors about buying, selling, or referring in West Linn, Oregon."
  jsonLd={[realEstateAgent()]}
>
  <PageHero
    crumb="Contact"
    eyebrow="Talk now"
    title={`Let's talk about<br/>your <span class="script">move</span>.`}
    lead="Whether you are buying, selling, or sending a client our way, a real local answer is one call or message away."
  />

  <section class="section--tight">
    <div class="wrap contact-layout">
      <div class="contact-info" data-reveal>
        <div class="contact-block">
          <p class="eyebrow">Talk now</p>
          <a class="contact-big" href={site.contact.phoneHref}>{site.contact.phone}</a>
        </div>
        <div class="contact-block">
          <p class="eyebrow">Office</p>
          <p class="contact-line">{site.city}, {site.state} {site.zip}</p>
          <p class="contact-line">{site.county}</p>
        </div>
        <div class="contact-block">
          <p class="eyebrow">Follow</p>
          <ul class="contact-social" role="list">
            {site.contact.social.map((s) => <li><a href={s.href}>{s.label}</a></li>)}
          </ul>
        </div>
        <div class="contact-block">
          <p class="eyebrow">Agent</p>
          <p class="contact-line">{site.agent.name}</p>
          <p class="contact-sub">{site.agent.designations.join(" · ")}</p>
        </div>
      </div>

      <div class="contact-form" data-reveal style="--reveal-delay: 100ms">
        <MarketReportForm
          formType="market-report"
          neighborhood="west-linn"
          neighborhoodName="West Linn"
          heading="Send us a message"
          blurb="Tell us what you are looking for and the best way to reach you. Melissa will get back to you personally."
          cta="Send message"
        />
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-layout { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: clamp(2rem, 1rem + 4vw, 4.5rem); align-items: start; }
  .contact-info { display: flex; flex-direction: column; gap: 2.2rem; }
  .contact-big { display: block; font-family: var(--font-display); font-size: clamp(2rem, 1.5rem + 2.5vw, 3rem); font-weight: 600; margin-top: 0.7rem; }
  .contact-big:hover { color: var(--gold-deep); }
  .contact-line { margin-top: 0.5rem; font-size: 1.05rem; }
  .contact-sub { color: var(--ink-muted); font-size: 0.85rem; margin-top: 0.3rem; }
  .contact-social { display: flex; gap: 1.2rem; margin-top: 0.7rem; }
  .contact-social a { font-size: 0.9rem; color: var(--ink-soft); }
  .contact-social a:hover { color: var(--gold-deep); }
  @media (max-width: 860px) { .contact-layout { grid-template-columns: 1fr; } }
</style>
