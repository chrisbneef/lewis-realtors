---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import BuySellRefer from "../components/BuySellRefer.astro";
import StatBand from "../components/StatBand.astro";
import SectionHead from "../components/SectionHead.astro";
import NeighborhoodCard from "../components/NeighborhoodCard.astro";
import ServiceCard from "../components/ServiceCard.astro";
import MeetMelissa from "../components/MeetMelissa.astro";
import MarketReportForm from "../components/MarketReportForm.astro";
import ValuationCTA from "../components/ValuationCTA.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import Testimonial from "../components/Testimonial.astro";
import LocalProsBridge from "../components/LocalProsBridge.astro";

import site from "../data/site.json";
import neighborhoods from "../data/neighborhoods.json";
import services from "../data/services.json";
import faq from "../data/faq.json";
import { realEstateAgent, faqSchema } from "../lib/schema.js";

const hoods = [...neighborhoods].sort((a, b) => a.order - b.order);
const jsonLd = [realEstateAgent(), faqSchema(faq)];
---

<Base
  title="West Linn, Oregon Real Estate"
  description="West Linn, Oregon real estate with Melissa Shaw of Lewis Realtors: free monthly market reports, real sold comps, and block-by-block expertise across 11 neighborhoods."
  jsonLd={jsonLd}
>
  <Hero />

  <BuySellRefer />

  <StatBand />

  <!-- Neighborhood grid -->
  <section class="section" id="neighborhoods">
    <div class="wrap">
      <div class="hoods-head">
        <SectionHead
          eyebrow="The neighborhoods"
          title={`Eleven West Linn neighborhoods,<br/>each with its own <span class="script">report</span>.`}
          lead="The neighborhood is the unit that matters. Start with the one you are watching and pull its market report. Bolton is live now, with the rest publishing as each month's data comes in."
        />
        <a class="btn btn--ghost" href="/market-reports">All market reports</a>
      </div>

      <div class="hoods-grid">
        {hoods.map((hood) => <NeighborhoodCard hood={hood} />)}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section--cream" id="services">
    <div class="wrap svc-layout">
      <div class="svc-aside">
        <SectionHead
          eyebrow="How we help"
          title={`Service that fits<br/>the way you move.`}
          lead="From a first purchase to a luxury listing, every service ties back to the neighborhoods it suits best."
        />
        <a class="btn" href="/services">See all services</a>
      </div>
      <div class="svc-list">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <!-- Local pros bridge -->
  <LocalProsBridge />

  <!-- Schools -->
  <section class="section">
    <div class="wrap schools" data-reveal>
      <div class="schools-copy">
        <p class="eyebrow">Schools matter here</p>
        <h2>{site.district}</h2>
        <p class="schools-lead measure">
          For most buyers in West Linn, the school feeder pattern is half the decision. We document
          the elementary, middle, and high school path for every neighborhood so you know exactly
          where a home leads before you fall for the kitchen.
        </p>
        <a class="link" href="/neighborhoods/bolton">See Bolton's feeders <span class="arrow">&rarr;</span></a>
      </div>
      <div class="schools-card card">
        <p class="schools-eg">Example feeder path</p>
        <ol class="feeder" role="list">
          <li><span class="feeder-step">Elementary</span><span class="feeder-name">Bolton Primary</span></li>
          <li><span class="feeder-step">Middle</span><span class="feeder-name">Rosemont Ridge Middle</span></li>
          <li><span class="feeder-step">High</span><span class="feeder-name">West Linn High</span></li>
        </ol>
      </div>
    </div>
  </section>

  <!-- Meet Melissa -->
  <MeetMelissa />

  <!-- Market report conversion band -->
  <section class="section section--ink" id="market-report">
    <div class="wrap report-layout">
      <div class="report-copy">
        <SectionHead
          eyebrow="The market report"
          title={`Real numbers,<br/>not a <span class="script">guess</span>.`}
        />
        <p class="report-lead">
          Each report is a one-page, plain-English read on a single neighborhood: median price,
          price per square foot, days on market, list-to-sale ratio, inventory, months of supply,
          the year-over-year trend, and three recent sold comps. Refreshed every month.
        </p>
        <ul class="report-points" role="list">
          <li>Built by hand from live RMLS data</li>
          <li>Three recent sold comps per neighborhood</li>
          <li>A real local answer one call behind every report</li>
        </ul>
      </div>
      <div class="report-form">
        <MarketReportForm formType="market-report" neighborhood="west-linn" neighborhoodName="West Linn" />
      </div>
    </div>
  </section>

  <!-- Valuation -->
  <ValuationCTA />

  <!-- Testimonial -->
  <Testimonial
    quote="Melissa knew our street better than we did. She priced it right, negotiated hard, and made the whole thing feel easy."
    name="A West Linn seller"
    detail="Replace with a verified client review before launch"
  />

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="wrap faq-layout">
      <SectionHead eyebrow="Good questions" title="Frequently asked" />
      <FaqAccordion items={faq} />
    </div>
  </section>

  <!-- Closer -->
  <section class="closer section--ink">
    <div class="wrap closer-inner" data-reveal>
      <p class="eyebrow eyebrow--center">West Linn, Oregon</p>
      <h2 class="closer-title">
        Let's make your real estate
        <span class="script">dreams</span>
        a reality.
      </h2>
      <div class="closer-actions">
        <a class="btn btn--gold btn--lg" href="#market-report">Get your market report</a>
        <a class="btn btn--ghost btn--lg" href={site.contact.phoneHref}>Call {site.contact.phone}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hoods-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  .hoods-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.6rem;
  }

  .svc-layout { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: clamp(2rem, 1rem + 4vw, 5rem); align-items: start; }
  .svc-aside { position: sticky; top: 122px; display: flex; flex-direction: column; gap: 2rem; }

  .schools { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: clamp(2rem, 1rem + 4vw, 4.5rem); align-items: center; }
  .schools-lead { margin-block: 1.2rem 1.6rem; color: var(--ink-soft); font-size: var(--fs-lead); font-weight: 300; }
  .schools h2 { margin-top: 0.4rem; }
  .schools-card { padding: 2rem; }
  .schools-eg { font-size: 0.7rem; letter-spacing: var(--tracking-eyebrow); text-transform: uppercase; color: var(--ink-muted); margin-bottom: 1.4rem; }
  .feeder { display: flex; flex-direction: column; gap: 0; counter-reset: step; }
  .feeder li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.1rem 0 1.1rem 2.4rem;
    position: relative;
    border-left: 2px solid color-mix(in srgb, var(--azure) 40%, transparent);
  }
  .feeder li::before {
    counter-increment: step;
    content: counter(step);
    position: absolute;
    left: -13px; top: 1rem;
    width: 24px; height: 24px;
    display: grid; place-items: center;
    font-size: 0.7rem; font-weight: 600;
    background: var(--grad-azure);
    color: #fff;
    border-radius: 50%;
  }
  .feeder li:last-child { border-left-color: transparent; }
  .schools-card { border-top: 3px solid var(--azure); }
  .feeder-step { font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); }
  .feeder-name { font-family: var(--font-display); font-size: 1.35rem; font-weight: 500; }

  .report-layout { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4.5rem); align-items: center; }
  .report-lead { color: var(--ink-onDark-soft); margin-top: 1.4rem; }
  .report-points { margin-top: 1.8rem; display: flex; flex-direction: column; gap: 0.9rem; }
  .report-points li {
    position: relative;
    padding-left: 1.8rem;
    color: var(--ink-onDark);
    font-size: 0.95rem;
  }
  .report-points li::before {
    content: "";
    position: absolute;
    left: 0; top: 0.55em;
    width: 9px; height: 9px;
    background: var(--grad-gold);
    border-radius: 50%;
  }

  .faq-layout { display: grid; grid-template-columns: 0.7fr 1.3fr; gap: clamp(2rem, 1rem + 3vw, 4rem); align-items: start; }

  .closer { padding-block: clamp(5rem, 3.5rem + 7vw, 9rem); position: relative; overflow: hidden; }
  .closer::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(80% 60% at 50% 120%, rgba(200,160,74,0.28), transparent 70%);
    pointer-events: none;
  }
  .closer-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 2rem; position: relative; }
  .closer-title { font-size: var(--fs-display); color: var(--ink-onDark); line-height: 1.02; max-width: 16ch; }
  .closer-title .script { font-size: 1.15em; line-height: 0.85; display: inline-block; }
  .closer-actions { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }

  @media (max-width: 980px) {
    .hoods-grid { grid-template-columns: repeat(2, 1fr); }
    .svc-layout, .schools, .report-layout, .faq-layout { grid-template-columns: 1fr; }
    .svc-aside { position: static; }
  }
  @media (max-width: 600px) {
    .hoods-grid { grid-template-columns: 1fr; }
  }
</style>
