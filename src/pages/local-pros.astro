---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import SectionHead from "../components/SectionHead.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import vendors from "../data/vendors.json";
import site from "../data/site.json";
import { realEstateAgent, faqSchema } from "../lib/schema.js";

const cats = vendors.categories;
const catLabel = (id) => cats.find((c) => c.id === id)?.label || id;

// A small featured row up top; the rest fill the searchable directory below.
const featured = vendors.vendors.filter((v) => v.featured);
const others = vendors.vendors.filter((v) => !v.featured);
const recommended = vendors.vendors.filter((v) => v.recommended); // real businesses, for schema
const usedCatIds = new Set(others.map((v) => v.category));
const gridCats = cats.filter((c) => usedCatIds.has(c.id));

const faq = [
  {
    q: "Who does Lewis Realtors recommend for a mortgage in West Linn?",
    a: "Melissa Shaw refers Renegade Home Mortgage, an independent West Linn broker (NMLS 227081) that shops a wide network of lenders to find the right loan. Reach them at (503) 974-3571 or renegadehomemtg.com.",
  },
  {
    q: "How do you choose the local pros you refer?",
    a: "These are people Lewis Realtors has worked with and trusts to treat your home and your timeline the way we would. We add a pro only when we are comfortable sending our own clients to them.",
  },
  {
    q: "Do I have to use the pros on this page?",
    a: "Never. This is a starting point, not a requirement. Use whoever you like. We share these names because clients keep asking us who to call in West Linn.",
  },
  {
    q: "Are you a local pro who wants to be listed?",
    a: "We are building this directory with a small group of trusted West Linn professionals. If that sounds like your work, reach out and tell us about it.",
  },
];

// ItemList of the real, recommended vendors so answer engines can cite them.
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Local home and real estate professionals recommended by Lewis Realtors in West Linn, Oregon",
  itemListElement: recommended
    .map((v, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": v.category === "mortgage" ? "MortgageBroker" : "LocalBusiness",
        name: v.name,
        url: v.url,
        telephone: v.phone,
        areaServed: v.serviceArea,
        address: {
          "@type": "PostalAddress",
          addressLocality: "West Linn",
          addressRegion: "OR",
          postalCode: "97068",
          addressCountry: "US",
        },
        ...(v.license ? { identifier: v.license } : {}),
      },
    })),
};

const jsonLd = [realEstateAgent(), itemList, faqSchema(faq)];
---

<Base
  title="Local Pros We Trust in West Linn"
  description="The local West Linn professionals Melissa Shaw and Lewis Realtors trust and refer: mortgage, inspection, title, insurance, contractors, and more."
  jsonLd={jsonLd}
>
  <PageHero
    crumb="Local Pros"
    eyebrow="Local pros we trust &middot; West Linn, Oregon"
    title={`Who to <span class="script">call</span><br/>in West Linn.`}
    lead="The local professionals Melissa Shaw knows, trusts, and refers, from your mortgage to your home inspection. Real names, vetted by people who do this every day."
  />

  <!-- Featured first: a small curated set (recommended + reserved spots) -->
  {featured.length > 0 && (
    <section class="lp-featured">
      <div class="wrap">
        <p class="eyebrow" data-reveal>Featured</p>
        <div class="feat-grid">
          {featured.map((v, i) => (
            <article class={`feat-card card ${v.recommended ? "" : "is-open"}`} data-reveal style={`--reveal-delay: ${i * 90}ms`}>
              <div class="feat-top">
                <span class="vcat">{catLabel(v.category)}</span>
                {v.recommended
                  ? <span class="pill pill--gold">Recommended</span>
                  : <span class="pill pill--placeholder">Featured spot</span>}
              </div>
              {v.logo
                ? <div class="feat-logo"><img src={v.logo} alt={`${v.name} logo`} width="512" height="198" loading="lazy" /></div>
                : <div class="feat-mark" aria-hidden="true">+</div>}
              <h2 class="feat-name">{v.name}</h2>
              {v.tagline && <p class="feat-tagline">{v.tagline}</p>}
              <p class="feat-blurb">{v.blurb}</p>
              {v.license && <p class="feat-meta">{v.license} &middot; {v.location}</p>}
              <div class="feat-foot">
                {v.url
                  ? <>
                      <a class="btn btn--gold btn--compact" href={v.url} target="_blank" rel="noopener">Visit {v.name.split(" ")[0]}</a>
                      {v.phone && <a class="link vfoot-phone" href={v.phoneHref}>{v.phone}</a>}
                    </>
                  : <a class="link" href="/contact">Inquire about this spot <span class="arrow">&rarr;</span></a>}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Search + filter, then the rest of the directory -->
  <section class="lp-directory" id="directory">
    <div class="wrap">
      <p class="dir-intro" data-reveal>Browse the rest of our local pros by category, or search by name.</p>

      <div class="dir-toolbar" data-reveal>
        <label class="dir-search">
          <span class="visually-hidden">Search local pros</span>
          <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <circle cx="11" cy="11" r="7" /><path d="M20 20l-3.5-3.5" stroke-linecap="round" />
          </svg>
          <input class="input" type="search" placeholder="Search by name or service" data-vendor-search />
        </label>
        <div class="dir-chips" data-vendor-chips role="group" aria-label="Filter by service">
          <button class="chip is-active" data-cat="all">All</button>
          {gridCats.map((c) => <button class="chip" data-cat={c.id}>{c.label}</button>)}
        </div>
      </div>

      <div class="dir-grid" data-vendor-grid>
        {others.map((v) => (
          <article
            class={`vcard card ${v.placeholder ? "is-placeholder" : ""}`}
            data-cat={v.category}
            data-name={`${v.name} ${catLabel(v.category)} ${v.blurb}`.toLowerCase()}
          >
            <div class="vcard-top">
              <span class="vcat">{catLabel(v.category)}</span>
              <span class="pill pill--placeholder">Spot reserved</span>
            </div>
            <h3 class="vname">{v.name}</h3>
            <p class="vblurb">{v.blurb}</p>
            <div class="vfoot">
              <a class="link" href="/contact">Ask Melissa <span class="arrow">&rarr;</span></a>
            </div>
          </article>
        ))}
      </div>

      <p class="dir-empty" data-vendor-empty hidden>
        No pros match that search yet. Try another service or clear the filter.
      </p>
    </div>
  </section>

  <!-- Invite local pros (the BNI / network growth, said neighborly) -->
  <section class="section--tight section--ink">
    <div class="wrap invite" data-reveal>
      <div>
        <p class="eyebrow">For local pros</p>
        <h2>Know a West Linn pro we should feature?</h2>
        <p class="invite-lead">
          We are building this directory with a small circle of professionals who treat clients the
          way we do. If that is you, or someone you trust, we would love an introduction.
        </p>
      </div>
      <a class="btn btn--gold btn--lg" href="/contact">Tell us about them</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="wrap faq-narrow">
      <SectionHead eyebrow="Good questions" title="Local pros, answered" />
      <FaqAccordion items={faq} />
    </div>
  </section>
</Base>

<script>
  const grid = document.querySelector("[data-vendor-grid]");
  if (grid) {
    const chips = Array.from(document.querySelectorAll("[data-vendor-chips] .chip"));
    const search = document.querySelector("[data-vendor-search]");
    const empty = document.querySelector("[data-vendor-empty]");
    const cards = Array.from(grid.querySelectorAll(".vcard"));
    let activeCat = "all";

    const apply = () => {
      const term = (search && search.value ? search.value : "").trim().toLowerCase();
      let shown = 0;
      cards.forEach((card) => {
        const catOk = activeCat === "all" || card.dataset.cat === activeCat;
        const termOk = !term || card.dataset.name.includes(term);
        const show = catOk && termOk;
        card.hidden = !show;
        if (show) shown++;
      });
      if (empty) empty.hidden = shown !== 0;
    };

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("is-active"));
        chip.classList.add("is-active");
        activeCat = chip.dataset.cat;
        apply();
      });
    });
    if (search) search.addEventListener("input", apply);
  }
</script>

<style>
  /* Tight spacing: hero -> featured -> directory read as one flow */
  .lp-featured { padding-block: clamp(0.75rem, 0.5rem + 1vw, 1.25rem) clamp(1.25rem, 0.75rem + 1.5vw, 1.75rem); }
  .lp-directory { padding-block: clamp(1.25rem, 0.75rem + 1.5vw, 1.75rem) clamp(3rem, 2rem + 4vw, 4.5rem); }

  /* Featured row (three cards) */
  .feat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 0.9rem; }
  .feat-card { display: flex; flex-direction: column; gap: 0.7rem; padding: 1.7rem; }
  .feat-card.is-open { border-style: dashed; background: transparent; }
  .feat-top { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; }
  .feat-logo { min-height: 56px; display: flex; align-items: center; margin: 0.3rem 0 0.4rem; }
  .feat-logo img { height: 52px; width: auto; max-width: 100%; border-radius: 4px; }
  .feat-mark {
    display: grid; place-items: center;
    width: 56px; height: 56px; margin: 0.3rem 0 0.4rem;
    border-radius: var(--radius);
    border: 1px dashed var(--azure);
    color: var(--azure-deep);
    font-size: 1.9rem;
  }
  .feat-name { font-size: 1.45rem; }
  .feat-card.is-open .feat-name { color: var(--ink-muted); }
  .feat-tagline { font-family: var(--font-display); font-style: italic; font-size: 1.05rem; color: var(--gold-deep); }
  .feat-blurb { color: var(--ink-soft); font-size: 0.92rem; flex-grow: 1; }
  .feat-meta { font-size: 0.74rem; color: var(--ink-muted); }
  .feat-foot {
    display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap;
    margin-top: 0.6rem; padding-top: 1.1rem; border-top: 1px solid var(--line);
  }
  .vfoot-phone { color: var(--gold-deep); }

  /* Directory intro line (not a heading) */
  .dir-intro { color: var(--ink-muted); font-size: 0.95rem; margin-bottom: 1.4rem; }

  /* Toolbar */
  .dir-toolbar { display: flex; flex-direction: column; gap: 1.2rem; margin: 2.5rem 0; }
  .dir-search { position: relative; display: flex; align-items: center; max-width: 420px; }
  .dir-search svg { position: absolute; left: 1rem; color: var(--ink-muted); pointer-events: none; }
  .dir-search .input { padding-left: 2.7rem; }
  .dir-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .chip {
    font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ink-soft); background: var(--bg-elevated);
    border: 1px solid var(--line-strong); border-radius: 100px;
    padding: 0.55em 1.05em;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease), background var(--dur) var(--ease);
  }
  .chip:hover { border-color: var(--gold); color: var(--gold-deep); }
  .chip.is-active { background: var(--noir); color: var(--ink-onDark); border-color: var(--noir); }

  /* Vendor grid */
  .dir-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .vcard { display: flex; flex-direction: column; gap: 0.8rem; padding: 1.6rem; }
  .vcard.is-placeholder { border-style: dashed; background: transparent; }
  .vcard-top { display: flex; align-items: center; justify-content: space-between; gap: 0.8rem; }
  .vcat { font-size: 0.66rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--azure-deep); }
  .vname { font-size: 1.45rem; }
  .vcard.is-placeholder .vname { color: var(--ink-muted); }
  .vblurb { font-size: 0.92rem; color: var(--ink-soft); flex-grow: 1; }
  .vfoot { margin-top: 0.4rem; padding-top: 1rem; border-top: 1px solid var(--line); }

  .dir-empty { margin-top: 2rem; color: var(--ink-muted); }

  /* Invite */
  .invite { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .invite h2 { margin-top: 0.5rem; }
  .invite-lead { color: var(--ink-onDark-soft); margin-top: 0.8rem; max-width: 56ch; }
  .faq-narrow { max-width: 820px; }

  @media (max-width: 900px) {
    .feat-grid { grid-template-columns: 1fr; }
    .dir-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .dir-grid { grid-template-columns: 1fr; }
  }
</style>
