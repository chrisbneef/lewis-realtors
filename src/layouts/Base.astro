---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import site from "../data/site.json";
import { webSite, webPage } from "../lib/schema.js";

const {
  title,
  description = "Hyper-local West Linn, Oregon real estate with Melissa Shaw of Lewis Realtors. Neighborhood market reports, live listing data, and block-by-block expertise.",
  jsonLd = [],
  ogImage = "/assets/lewis-logo.png",
} = Astro.props;

const fullTitle = title ? `${title} | ${site.brand}` : `${site.brand} | West Linn, Oregon Real Estate`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// Build-time freshness stamp; refreshes on every deploy.
const buildDate = new Date().toISOString();
// Every page carries WebSite + WebPage (freshness + author); pages add their own.
const passed = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const schemas = [
  webSite(),
  webPage({ path: Astro.url.pathname, name: fullTitle, dateModified: buildDate }),
  ...passed,
];
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/assets/lewis-logo.png" />

    <!-- Dark mode is on hold: the site is locked to light (data-theme="light" on
         <html>). The dark-theme styles and toggle logic remain in place to re-enable
         later. To restore auto-detect + toggle, bring back the detection script here
         and the toggle button in Header.astro. -->
    <script is:inline>
      document.documentElement.dataset.theme = "light";
    </script>

    <!-- Fonts approximate the Brand Guide faces (Classico / Venti CF / Haute
         Couture) with Marcellus (elegant display), Jost (clean body), and
         Parisienne (signature accent). Replace with the licensed brand fonts
         when available. Cormorant Garamond stays loaded as a display fallback. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Marcellus&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500;600&family=Parisienne&display=swap"
      rel="stylesheet"
    />

    {schemas.filter(Boolean).map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <slot name="head" />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script src="../scripts/app.js"></script>

    <style>
      .skip-link {
        position: absolute;
        left: 1rem;
        top: -3rem;
        z-index: 1000;
        background: var(--noir);
        color: var(--ink-onDark);
        padding: 0.6rem 1rem;
        border-radius: var(--radius-sm);
        transition: top 0.2s ease;
      }
      .skip-link:focus { top: 1rem; }
      body.no-scroll { overflow: hidden; }
    </style>
  </body>
</html>
