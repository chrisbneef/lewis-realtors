---
// Placeholder testimonial. Replace quote and attribution with a real client review.
const { quote, name, detail } = Astro.props;
---

<section class="quote section--ink">
  <div class="wrap quote-inner" data-reveal>
    <span class="quote-mark script" aria-hidden="true">&ldquo;</span>
    <blockquote class="quote-text">
      {quote}
    </blockquote>
    <figcaption class="quote-by">
      <span class="rule--gold" aria-hidden="true"></span>
      <span class="quote-name">{name}</span>
      <span class="quote-detail">{detail}</span>
      <span class="tag-sample">Sample review</span>
    </figcaption>
  </div>
</section>

<style>
  .quote { padding-block: clamp(4rem, 3rem + 5vw, 7rem); }
  .quote-inner { max-width: 56ch; margin-inline: auto; text-align: center; position: relative; }
  .quote-mark {
    font-size: 8rem;
    line-height: 0;
    display: block;
    height: 2.4rem;
    color: var(--gold-bright);
  }
  .quote-text {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.2rem + 1.8vw, 2.6rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.3;
    color: var(--ink-onDark);
    margin: 0;
  }
  .quote-by { display: flex; flex-direction: column; align-items: center; gap: 0.6rem; margin-top: 2.4rem; }
  .quote-by .rule--gold { margin-bottom: 0.6rem; }
  .quote-name { font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold-bright); font-size: 0.8rem; }
  .quote-detail { font-size: 0.8rem; color: var(--ink-onDark-soft); }
</style>
