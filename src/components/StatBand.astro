---
// West Linn market overview. Values are clearly-labeled placeholders until the
// first RMLS pull is loaded. Per brand rules we never invent market numbers.
const stats = [
  { value: "97068", label: "West Linn ZIP", sample: false },
  { value: "11", label: "Neighborhoods we cover", sample: false },
  { value: "Sample", label: "Median sale price", sample: true },
  { value: "Sample", label: "Avg days on market", sample: true },
];
---

<section class="band section--ink">
  <div class="wrap band-inner">
    <p class="band-intro" data-reveal>
      One city, gone deep. Here is West Linn at a glance, refreshed monthly from
      live RMLS data.
    </p>
    <ul class="band-stats" role="list">
      {stats.map((s, i) => (
        <li data-reveal style={`--reveal-delay: ${i * 80}ms`}>
          <span class={`band-val ${s.sample ? "band-val--market" : "band-val--place"}`}>{s.value}</span>
          <span class="band-label">
            {s.label}
            {s.sample && <span class="tag-sample">Sample</span>}
          </span>
        </li>
      ))}
    </ul>
  </div>
  <span class="band-glow" aria-hidden="true"></span>
</section>

<style>
  .band { padding-block: clamp(3rem, 2rem + 3vw, 4.5rem); position: relative; overflow: hidden; }
  .band-glow {
    position: absolute;
    top: 50%; right: -6%;
    width: 38%; height: 220%;
    transform: translateY(-50%);
    background: radial-gradient(circle, rgba(108,130,165,0.32), transparent 68%);
    pointer-events: none;
    z-index: 0;
  }
  .band-inner { position: relative; z-index: 1; }
  .band-inner { display: grid; grid-template-columns: 0.8fr 2.2fr; gap: 2.5rem; align-items: center; }
  .band-intro {
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.4;
    color: var(--ink-onDark);
    max-width: 26ch;
  }
  .band-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .band-val {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.4rem + 1.6vw, 2.8rem);
    font-weight: 600;
    line-height: 1;
  }
  .band-val--market { color: var(--gold-bright); }
  .band-val--place { color: var(--azure-bright); }
  .band-label {
    display: block;
    margin-top: 0.6rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-onDark-soft);
  }
  .band-label .tag-sample { display: inline-block; margin-top: 0.4rem; }

  @media (max-width: 820px) {
    .band-inner { grid-template-columns: 1fr; gap: 1.8rem; }
    .band-stats { grid-template-columns: repeat(2, 1fr); gap: 1.6rem; }
  }
</style>
