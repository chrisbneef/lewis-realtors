---
const { service } = Astro.props;
---

<a class="svc" href={`/services#${service.slug}`} data-reveal>
  <div class="svc-top">
    <span class="svc-num">{service.num}</span>
    <span class="svc-for">{service.for}</span>
  </div>
  <h3 class="svc-name">{service.name}</h3>
  <p class="svc-summary">{service.summary}</p>
  <span class="link">Explore <span class="arrow">&rarr;</span></span>
</a>

<style>
  .svc {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.8rem 0 2rem;
    border-top: 1px solid var(--line-strong);
    transition: padding-left var(--dur) var(--ease);
  }
  .svc:hover { padding-left: 0.6rem; }
  .svc-top { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
  .svc-num {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--gold-deep);
  }
  .svc-for {
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .svc-name { font-size: 1.7rem; transition: color var(--dur) var(--ease); }
  .svc:hover .svc-name { color: var(--gold-deep); }
  .svc-summary { color: var(--ink-soft); font-size: 0.95rem; }
</style>
