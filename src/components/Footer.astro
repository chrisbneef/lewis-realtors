---
import site from "../data/site.json";
const year = 2026;
---

<footer class="site-footer section--ink">
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-brand">
        <img src="/assets/lewis-logo.png" alt={site.brand} width="180" height="78" />
        <p class="foot-tag">
          Hyper-local real estate in <span class="script">West&nbsp;Linn</span>, Oregon.
        </p>
        <p class="foot-note">{site.city}, {site.state} {site.zip} &middot; {site.county}</p>
      </div>

      <nav class="foot-col" aria-label="Footer">
        <h3 class="foot-h">Explore</h3>
        <ul role="list">
          {site.nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          <li><a href="/financing">Financing Partner</a></li>
        </ul>
      </nav>

      <div class="foot-col">
        <h3 class="foot-h">Talk now</h3>
        <a class="foot-phone" href={site.contact.phoneHref}>{site.contact.phone}</a>
        <a class="link" href="/contact">{site.contact.emailLabel}<span class="arrow">&rarr;</span></a>
        <p class="foot-hours">{site.contact.hoursText}</p>
        <h3 class="foot-h foot-h--social">Follow</h3>
        <ul role="list" class="foot-social">
          {site.contact.social.map((s) => <li><a href={s.href}>{s.label}</a></li>)}
        </ul>
      </div>
    </div>

    <hr class="rule" style="background: var(--line-onDark); margin-block: 2.5rem;" />

    <div class="foot-legal">
      <p class="foot-license">{site.compliance.license}</p>
      <p class="foot-idx">{site.compliance.idx}</p>
      <p class="foot-copy">
        &copy; {year} {site.brand}. All rights reserved. Equal Housing Opportunity.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer { padding-block: clamp(3.5rem, 2.5rem + 4vw, 6rem) 3rem; }
  .foot-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.2fr;
    gap: 3rem;
  }
  .foot-brand img {
    height: 60px; width: auto;
    filter: brightness(0) invert(1) sepia(0.35) saturate(2.4) hue-rotate(2deg);
  }
  .foot-tag {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-top: 1.2rem;
    color: var(--ink-onDark);
  }
  .foot-tag .script { font-size: 1.9rem; }
  .foot-note {
    margin-top: 0.8rem;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-onDark-soft);
  }
  .foot-h {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--gold-bright);
    margin-bottom: 1.2rem;
  }
  .foot-h--social { margin-top: 2rem; }
  .foot-hours { margin-top: 0.8rem; font-size: 0.82rem; color: var(--ink-onDark-soft); max-width: 24ch; }
  .foot-col ul { display: flex; flex-direction: column; gap: 0.75rem; }
  .foot-col a {
    font-size: 0.9rem;
    color: var(--ink-onDark-soft);
    transition: color var(--dur) var(--ease);
  }
  .foot-col a:hover { color: var(--ink-onDark); }
  .foot-social { flex-direction: row !important; gap: 1.2rem !important; }
  .foot-phone {
    display: block;
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--ink-onDark);
    margin-bottom: 0.8rem;
  }
  .foot-phone:hover { color: var(--gold-bright); }

  .foot-legal { display: flex; flex-direction: column; gap: 1rem; }
  .foot-license { font-size: 0.8rem; color: var(--ink-onDark-soft); }
  .foot-idx {
    font-size: 0.72rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--ink-onDark-soft) 78%, transparent);
    max-width: 90ch;
  }
  .foot-copy {
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-onDark-soft);
  }

  @media (max-width: 860px) {
    .foot-top { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
