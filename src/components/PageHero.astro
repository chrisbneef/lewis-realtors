---
const { eyebrow, title, lead, crumb } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero-bg" aria-hidden="true"></div>
  <div class="wrap">
    {crumb && (
      <nav class="crumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span><span aria-current="page">{crumb}</span>
      </nav>
    )}
    <div class="page-hero-inner" data-reveal>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1 set:html={title} />
      {lead && <p class="page-hero-lead measure">{lead}</p>}
    </div>
  </div>
</section>

<style>
  .page-hero { position: relative; padding-block: clamp(2.5rem, 2rem + 3vw, 4.5rem) clamp(2rem, 1.5rem + 2vw, 3.5rem); overflow: hidden; }
  .page-hero-bg {
    position: absolute; inset: 0; z-index: -1;
    background: radial-gradient(60% 80% at 85% 0%, rgba(200,160,74,0.18), transparent 60%);
  }
  .crumb { display: flex; align-items: center; gap: 0.6rem; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 2rem; }
  .crumb a:hover { color: var(--gold-deep); }
  .crumb span[aria-current] { color: var(--ink); }
  .page-hero-inner { max-width: 60ch; }
  .page-hero h1 { font-size: clamp(2.6rem, 1.8rem + 4vw, 5rem); margin-top: 1rem; }
  :global(.page-hero h1 .script) { font-size: 1.15em; line-height: 0.85; display: inline-block; }
  .page-hero-lead { margin-top: 1.4rem; font-size: var(--fs-lead); color: var(--ink-soft); font-weight: 300; }
</style>
