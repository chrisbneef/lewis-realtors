---
const {
  formType = "market-report",
  neighborhood = "west-linn",
  neighborhoodName = "West Linn",
  heading,
  blurb,
  cta = "Send my report",
} = Astro.props;

const isValuation = formType === "valuation";
const defaultHeading = isValuation
  ? "What is my home worth?"
  : `Get the ${neighborhoodName} market report`;
const defaultBlurb = isValuation
  ? "Tell us about your home and Melissa will prepare a personalized valuation built on real neighborhood sold data, not an automated guess."
  : `Median price, days on market, list-to-sale ratio, inventory, and three recent sold comps for ${neighborhoodName}. Refreshed every month from live RMLS data and sent straight to your inbox.`;
---

<form class="lead-form" data-lead-form data-form-type={formType} data-neighborhood={neighborhood}>
  <div class="lead-head">
    <h3 class="lead-title">{heading || defaultHeading}</h3>
    <p class="lead-blurb">{blurb || defaultBlurb}</p>
  </div>

  <div class="lead-grid">
    <div class="field">
      <label for={`name-${formType}-${neighborhood}`}>Name</label>
      <input class="input" id={`name-${formType}-${neighborhood}`} name="name" type="text" autocomplete="name" placeholder="Your name" required />
    </div>
    <div class="field">
      <label for={`email-${formType}-${neighborhood}`}>Email</label>
      <input class="input" id={`email-${formType}-${neighborhood}`} name="email" type="email" autocomplete="email" placeholder="you@email.com" required />
    </div>
    {isValuation && (
      <div class="field field--full">
        <label for={`address-${neighborhood}`}>Property address</label>
        <input class="input" id={`address-${neighborhood}`} name="address" type="text" autocomplete="street-address" placeholder="Street, West Linn, OR" />
      </div>
    )}
  </div>

  <!-- CAPTCHA mounts here once Cloudflare Turnstile keys are added (see capture-lead.js TODO). -->
  <div class="captcha-slot" data-captcha aria-hidden="true"></div>

  <button class="btn btn--gold btn--lg lead-submit" type="submit">
    <span class="submit-label">{cta}</span>
    <span class="submit-spin" aria-hidden="true"></span>
  </button>

  <p class="lead-fineprint">
    No spam. Your information goes only to Melissa Shaw at Lewis Realtors.
  </p>

  <div class="lead-status" data-status role="status" aria-live="polite"></div>
</form>

<script>
  document.querySelectorAll("[data-lead-form]").forEach((form) => {
    const status = form.querySelector("[data-status]");
    const btn = form.querySelector(".lead-submit");
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      btn.classList.add("is-loading");
      btn.disabled = true;
      status.className = "lead-status";
      status.textContent = "";

      const payload = {
        name: form.name.value.trim(),
        email: form.email.value.trim(),
        address: form.address ? form.address.value.trim() : undefined,
        formType: form.dataset.formType,
        neighborhood: form.dataset.neighborhood,
        token: form.querySelector("[name='cf-turnstile-response']")?.value || "dev-stub",
      };

      try {
        const res = await fetch("/api/capture-lead", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          form.reset();
          status.className = "lead-status is-ok";
          status.textContent = data.message || "Thank you. Your report is on the way to your inbox.";
        } else {
          throw new Error(data.error || "Something went wrong.");
        }
      } catch (err) {
        status.className = "lead-status is-error";
        status.textContent = "We could not send that just now. Please call (503) 489-8367 or try again.";
      } finally {
        btn.classList.remove("is-loading");
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-top: 3px solid transparent;
    border-image: var(--grad-gold) 1;
    border-radius: var(--radius-lg);
    padding: clamp(1.6rem, 1rem + 2vw, 2.6rem);
    box-shadow: var(--shadow);
  }
  .lead-title { font-size: clamp(1.5rem, 1.2rem + 1.3vw, 2.1rem); }
  .lead-blurb { margin-top: 0.7rem; color: var(--ink-soft); font-size: 0.95rem; }
  .lead-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field--full { grid-column: 1 / -1; }
  .captcha-slot:empty { display: none; }

  .lead-submit { position: relative; align-self: flex-start; }
  .lead-submit .submit-spin {
    width: 15px; height: 15px;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    display: none;
    animation: spin 0.7s linear infinite;
  }
  .lead-submit.is-loading .submit-label { opacity: 0.6; }
  .lead-submit.is-loading .submit-spin { display: inline-block; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .lead-fineprint { font-size: 0.74rem; color: var(--ink-muted); }
  .lead-status { font-size: 0.9rem; }
  .lead-status.is-ok { color: var(--azure-deep); font-weight: 500; }
  .lead-status.is-error { color: #b23b3b; }

  @media (max-width: 520px) {
    .lead-grid { grid-template-columns: 1fr; }
  }
</style>
