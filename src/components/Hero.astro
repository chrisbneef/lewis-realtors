---
import site from "../data/site.json";
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <span class="orb orb-1"></span>
    <span class="orb orb-2"></span>
  </div>

  <div class="wrap hero-inner">
    <div class="hero-copy">
      <p class="eyebrow" data-reveal>West Linn, Oregon &middot; ZIP {site.zip}</p>
      <h1 data-reveal style="--reveal-delay: 80ms">
        Know the
        <span class="script">neighborhood</span>
        before you know the home.
      </h1>
      <p class="hero-lead measure" data-reveal style="--reveal-delay: 180ms">
        Lewis Realtors is Melissa Shaw's West Linn, Oregon real estate office, with 20+ years of
        local experience and more than $108 million sold since 2016. Each of the 11 West Linn
        neighborhoods (ZIP 97068) gets its own free monthly market report.
      </p>
      <div class="hero-actions" data-reveal style="--reveal-delay: 280ms">
        <a class="btn btn--gold btn--lg" href="#market-report">Get your market report</a>
        <a class="btn btn--ghost btn--lg" href="/home-value">What is my home worth?</a>
      </div>
      <ul class="hero-proof" role="list" data-reveal style="--reveal-delay: 380ms">
        {site.agent.stats.map((s) => (
          <li>
            <span class="proof-val">{s.value}</span>
            <span class="proof-label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>

    <figure class="hero-figure" data-reveal style="--reveal-delay: 220ms">
      <div class="hero-card">
        <div class="hero-photo">
          <img
            src="/assets/melissa-sold.png"
            alt="Melissa Shaw of Lewis Realtors holding a Sold sign in West Linn, Oregon"
            width="685"
            height="843"
            fetchpriority="high"
          />
        </div>
        <figcaption class="hero-meta">
          <p class="meta-name">{site.agent.name}</p>
          <p class="meta-role">{site.agent.role}</p>
          <a class="meta-phone" href={site.contact.phoneHref}>
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
              <path d="M6.5 3.5h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 4.5 5.5a2 2 0 0 1 2-2Z" stroke-linejoin="round"/>
            </svg>
            <span>{site.contact.phone}</span>
          </a>
        </figcaption>
      </div>
    </figure>
  </div>
</section>

<style>
  .hero {
    position: relative;
    /* fill one screen below the sticky header so the whole hero is above the fold */
    min-height: calc(100svh - 98px);
    display: flex;
    align-items: center;
    padding-block: clamp(1.25rem, 0.5rem + 2.5vw, 2.75rem);
    overflow: hidden;
  }
  .hero-bg { position: absolute; inset: 0; z-index: -1; }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.5;
  }
  .orb-1 {
    width: 40vw; height: 40vw;
    top: -10%; right: -8%;
    background: radial-gradient(circle, rgba(200,160,74,0.5), transparent 70%);
  }
  .orb-2 {
    width: 40vw; height: 40vw;
    bottom: -18%; left: -12%;
    background: radial-gradient(circle, rgba(108,130,165,0.55), transparent 70%);
    opacity: 0.7;
  }

  .hero-inner {
    width: 100%;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(2rem, 1rem + 4vw, 5rem);
  }
  .hero h1 {
    margin-block: 1rem 0;
    font-size: clamp(2.4rem, 1.5rem + 3.4vw, 4.4rem);
  }
  .hero h1 .script {
    display: inline-block;
    font-size: 1.15em;
    line-height: 0.85;
    padding-inline: 0.06em;
  }
  .hero-lead {
    margin-top: 1.3rem;
    font-size: var(--fs-lead);
    color: var(--ink-soft);
    font-weight: 300;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.8rem;
  }
  /* equal width, side by side; wrap to stack only when the column is too narrow */
  .hero-actions .btn {
    flex: 1 1 240px;
    padding-inline: 1.2em;
    letter-spacing: 0.12em;
  }
  .hero-proof {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.25rem, 1rem + 2vw, 2.75rem);
    margin-top: 2rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--line);
  }
  .proof-val {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 1.4rem + 1.2vw, 2.3rem);
    font-weight: 600;
    color: var(--gold-deep);
    line-height: 1;
  }
  .proof-label {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    max-width: 18ch;
  }

  .hero-figure { position: relative; margin: 0; justify-self: end; align-self: center; width: 100%; max-width: 400px; }
  .hero-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 0.9rem;
    box-shadow: var(--shadow-lg);
  }
  .hero-photo {
    position: relative;
    width: 100%;
    /* matches the photo's native portrait ratio so it fills the card cleanly */
    aspect-ratio: 685 / 843;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--cream-deep);
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 1.05rem 0.55rem 0.5rem;
  }
  .meta-name { font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; line-height: 1.05; }
  .meta-role { font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-muted); }
  .meta-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: 100%;
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--gold-deep);
    white-space: nowrap;
    transition: color var(--dur) var(--ease);
  }
  .meta-phone svg { flex-shrink: 0; }
  .meta-phone:hover { color: var(--noir); }

  @media (max-width: 900px) {
    .hero {
      min-height: auto;
      padding-block: clamp(2rem, 1.5rem + 3vw, 3.5rem);
    }
    .hero-inner { grid-template-columns: 1fr; }
    .hero-photo { max-height: none; }
    .hero-figure { justify-self: center; align-self: auto; margin-top: 2rem; max-width: 360px; }
  }

  /* short desktop viewports: compress so it still clears the fold */
  @media (min-width: 901px) and (max-height: 780px) {
    .hero h1 { font-size: clamp(2.1rem, 1.4rem + 2.4vw, 3.4rem); }
    .hero-lead { margin-top: 0.9rem; font-size: 1.05rem; }
    .hero-actions { margin-top: 1.3rem; }
    .hero-proof { margin-top: 1.4rem; padding-top: 1.1rem; }
    /* shrink the whole card (not just height) so the photo still fills its width */
    .hero-figure { max-width: 340px; }
  }
</style>
