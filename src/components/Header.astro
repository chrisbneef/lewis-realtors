---
import site from "../data/site.json";
---

<header class="site-header" data-header>
  <div class="wrap header-inner">
    <a class="brand" href="/" aria-label={`${site.brand} home`}>
      <img src="/assets/lewis-logo.png" alt={site.brand} width="179" height="78" />
    </a>

    <nav class="nav" data-nav aria-label="Primary">
      <ul role="list" class="nav-list">
        {site.nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
      <div class="nav-cta">
        <a class="btn btn--gold btn--compact" href="/market-reports">Market Reports</a>
      </div>
    </nav>

    <div class="header-tools">
      <!-- Dark-mode toggle is on hold (site locked to light). To re-enable, restore
           the button here and the detection script in Base.astro. -->
      <button class="menu-btn" data-menu-btn aria-expanded="false" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    backdrop-filter: blur(12px) saturate(1.1);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease);
  }
  .site-header.is-stuck {
    border-bottom-color: var(--line);
    box-shadow: var(--shadow-sm);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 98px;
  }
  .brand img {
    height: 78px;
    width: auto;
    transition: opacity var(--dur) var(--ease);
  }
  :global(:root[data-theme="dark"]) .brand img {
    filter: brightness(0) invert(1) sepia(0.4) saturate(2) hue-rotate(2deg);
  }

  .nav { display: flex; align-items: center; gap: 2rem; }
  .nav-list {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    margin: 0;
  }
  .nav-list a {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-soft);
    position: relative;
    padding-block: 0.3rem;
    transition: color var(--dur) var(--ease);
  }
  .nav-list a::after {
    content: "";
    position: absolute;
    left: 0; bottom: 0;
    width: 100%; height: 1px;
    background: var(--grad-gold);
    transform: scaleX(0.001);
    transform-origin: left;
    transition: transform var(--dur) var(--ease);
  }
  .nav-list a:hover { color: var(--ink); }
  .nav-list a:hover::after { transform: scaleX(1); }

  .nav-cta { display: flex; align-items: center; gap: 1.25rem; }
  /* compact header CTA so "Market Reports" stays on one tidy line */
  .nav-cta .btn--compact { padding: 0.72em 1.35em; font-size: 0.72rem; }

  .header-tools { display: flex; align-items: center; gap: 0.5rem; }
  .icon-btn {
    display: grid;
    place-items: center;
    width: 40px; height: 40px;
    border-radius: 50%;
    color: var(--ink-soft);
    border: 1px solid var(--line);
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .icon-btn:hover { color: var(--gold-deep); border-color: var(--gold); }
  .icon-btn svg { grid-area: 1 / 1; transition: opacity 0.3s var(--ease), transform 0.3s var(--ease); }
  .icon-btn .moon { opacity: 0; transform: rotate(-30deg) scale(0.6); }
  :global(:root[data-theme="dark"]) .icon-btn .sun { opacity: 0; transform: rotate(30deg) scale(0.6); }
  :global(:root[data-theme="dark"]) .icon-btn .moon { opacity: 1; transform: none; }

  .menu-btn {
    display: none;
    width: 44px; height: 44px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
  }
  .menu-btn span {
    width: 24px; height: 2px;
    background: var(--ink);
    transition: transform 0.3s var(--ease), opacity 0.3s var(--ease);
  }
  .menu-btn.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-btn.is-open span:nth-child(2) { opacity: 0; }
  .menu-btn.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 980px) {
    .menu-btn { display: flex; }
    .nav {
      position: fixed;
      top: 98px; left: 0; right: 0; bottom: auto;
      /* drop down to fit its content; only scroll on very short screens */
      max-height: calc(100dvh - 98px);
      flex-direction: column;
      justify-content: flex-start;
      align-items: stretch;
      gap: 0.75rem;
      background: var(--bg);
      padding: 0.5rem var(--gutter) 1.5rem;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow);
      /* hide in place (no off-screen transform) so the page cannot be swiped to it */
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: opacity 0.3s var(--ease), transform 0.35s var(--ease), visibility 0.3s;
    }
    .nav.is-open { opacity: 1; visibility: visible; transform: none; }

    .nav-list { flex-direction: column; gap: 0; width: 100%; }
    .nav-list li { border-bottom: 1px solid var(--line); }
    .nav-list a {
      display: block;
      width: 100%;
      padding-block: 0.95rem;
      font-size: 1rem;
      color: var(--ink);
    }
    .nav-list a::after { display: none; }

    .nav-cta { flex-direction: column; gap: 1rem; margin-top: 1.1rem; }
    .nav-cta .btn--compact { width: 100%; font-size: 0.82rem; padding: 1.05em 1.8em; }
  }

  /* keep the bigger logo from crowding at tablet widths */
  @media (max-width: 1080px) {
    .nav-list { gap: 1.35rem; }
    .nav-list a { letter-spacing: 0.12em; }
  }
  @media (max-width: 560px) {
    .header-inner { min-height: 80px; }
    .brand img { height: 60px; }
    .nav { top: 80px; max-height: calc(100dvh - 80px); }
  }
</style>
