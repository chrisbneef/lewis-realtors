---
// "Life in West Linn" - the lifestyle/emotional sell. Three looping clips of the
// real amenities that come with the address. Muted autoplay loops with a poster
// fallback for reduced-motion / slow connections. Places are named accurately
// (Tumwater Vineyard, Oregon Golf Club) since those are confirmed locations.
const tiles = [
  { mp4: "/assets/video/life-vineyard.mp4", poster: "/assets/video/life-vineyard.jpg",
    place: "Tumwater Vineyard", blurb: "Wine country, minutes from home." },
  { mp4: "/assets/video/life-golf.mp4", poster: "/assets/video/life-golf.jpg",
    place: "Oregon Golf Club", blurb: "Championship fairways in the backyard." },
  { mp4: "/assets/video/life-countryside.mp4", poster: "/assets/video/life-countryside.jpg",
    place: "West Linn countryside", blurb: "Room to breathe on the edge of town." },
];
---

<section class="life section--ink" aria-label="Life in West Linn">
  <div class="wrap">
    <div class="life-head" data-reveal>
      <p class="eyebrow eyebrow--center">Life in West Linn</p>
      <h2 class="center life-title">The life that comes<br />with the <span class="script">address</span>.</h2>
      <p class="life-intro center measure">
        The Willamette at the bottom of the hill, wine country ten minutes out, championship
        fairways, and room to breathe. This is what West Linn offers beyond the front door.
      </p>
    </div>

    <div class="life-grid">
      {tiles.map((t, i) => (
        <figure class="life-tile" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
          <img class="life-poster" src={t.poster} alt="" loading="lazy" decoding="async" />
          <video class="life-video" autoplay muted loop playsinline preload="none" poster={t.poster}>
            <source src={t.mp4} type="video/mp4" />
          </video>
          <figcaption class="life-cap">
            <span class="life-place">{t.place}</span>
            <span class="life-blurb">{t.blurb}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .life-head { display: flex; flex-direction: column; align-items: center; gap: 1rem; margin-bottom: 3rem; }
  .life-title { max-width: 20ch; }
  .life-intro { color: var(--ink-onDark-soft); font-size: var(--fs-lead); font-weight: 300; }

  .life-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  .life-tile {
    position: relative;
    aspect-ratio: 4 / 3;
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .life-poster,
  .life-video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .life-video { opacity: 0; transition: opacity 0.8s ease; }
  .life-video[data-ready] { opacity: 1; }
  @media (prefers-reduced-motion: reduce) { .life-video { display: none; } }

  .life-cap {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 1;
    display: flex; flex-direction: column; gap: 0.15rem;
    padding: 2.4rem 1.3rem 1.2rem;
    background: linear-gradient(0deg, rgba(6, 6, 6, 0.85) 0%, rgba(6, 6, 6, 0.35) 55%, transparent 100%);
  }
  .life-place { font-family: var(--font-display); font-size: 1.3rem; color: #fff; line-height: 1.1; }
  .life-blurb { font-size: 0.85rem; color: var(--ink-onDark-soft); }

  @media (max-width: 820px) {
    .life-grid { grid-template-columns: 1fr; gap: 1.1rem; }
    .life-tile { aspect-ratio: 16 / 9; }
  }
</style>

<script>
  // Play only when scrolled into view, and reveal once ready (poster carries the
  // first paint). Keeps three videos from all fetching/decoding on load.
  const vids = document.querySelectorAll("video.life-video");
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      const v = e.target;
      if (e.isIntersecting) {
        if (v.preload === "none") v.preload = "auto";
        v.play?.().catch(() => {});
      } else {
        v.pause?.();
      }
    });
  }, { rootMargin: "200px" });
  vids.forEach((v) => {
    const show = () => v.setAttribute("data-ready", "");
    if (v.readyState >= 3) show();
    else v.addEventListener("canplay", show, { once: true });
    io.observe(v);
  });
</script>
