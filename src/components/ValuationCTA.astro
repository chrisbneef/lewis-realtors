---
import site from "../data/site.json";
---

<section class="val">
  <div class="wrap val-inner" data-reveal>
    <div class="val-copy">
      <p class="eyebrow">For sellers</p>
      <h2>What is your <span class="script">home</span> worth today?</h2>
      <p class="val-lead measure">
        Skip the automated estimate. Melissa prepares a personalized valuation from the actual
        sold comps on your street, then walks you through what it means for your timing and price.
      </p>
    </div>
    <div class="val-action">
      <a class="btn btn--gold btn--lg" href="/home-value">Request my valuation</a>
      <a class="phone-link" href={site.contact.phoneHref}>or call {site.contact.phone}</a>
    </div>
  </div>
</section>

<style>
  .val { padding-block: var(--section-y); }
  .val-inner {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    align-items: center;
    gap: clamp(2rem, 1rem + 4vw, 5rem);
    background: var(--bg-alt);
    border-radius: var(--radius-lg);
    padding: clamp(2.2rem, 1.5rem + 3vw, 4rem);
    border: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  .val-inner::before {
    content: "";
    position: absolute;
    top: -40%; right: -10%;
    width: 50%; height: 180%;
    background: radial-gradient(circle, rgba(200,160,74,0.22), transparent 70%);
    pointer-events: none;
  }
  .val h2 { margin-top: 0.6rem; }
  .val h2 .script { font-size: 1.2em; line-height: 0.85; display: inline-block; }
  .val-lead { margin-top: 1.2rem; color: var(--ink-soft); }
  .val-action { display: flex; flex-direction: column; align-items: flex-start; gap: 1rem; }
  .phone-link { font-size: 0.85rem; color: var(--ink-muted); letter-spacing: 0.04em; }
  .phone-link:hover { color: var(--gold-deep); }

  @media (max-width: 820px) {
    .val-inner { grid-template-columns: 1fr; }
  }
</style>
