---
import { priceLabel } from "../lib/market.js";
const { hood } = Astro.props;
const href = `/neighborhoods/${hood.slug}`;
const num = String(hood.order).padStart(2, "0");
const range = priceLabel(hood.slug);
---

<a class="hood-card card" href={href} data-reveal>
  <div class:list={["hood-photo", { "hood-photo--placeholder": !hood.image }]}>
    {hood.image
      ? <img src={hood.image} alt={`${hood.name}, West Linn, Oregon`} loading="lazy" width="704" height="440" />
      : <span class="hood-photo-mark" aria-hidden="true">{hood.character}</span>}
    <span class="hood-scrim" aria-hidden="true"></span>
    <span class="hood-num">{num}</span>
    {hood.complete
      ? <span class="pill pill--gold">Report ready</span>
      : <span class="pill pill--placeholder">Report soon</span>}
  </div>
  <div class="hood-body">
    <h3 class="hood-name">{hood.name}</h3>
    <p class="hood-tagline">{hood.tagline}</p>
    <div class="hood-foot">
      <span class="hood-range">{range}</span>
      <span class="link arrow-only" aria-hidden="true"><span class="arrow">&rarr;</span></span>
    </div>
  </div>
</a>

<style>
  .hood-card { display: flex; flex-direction: column; overflow: hidden; }
  .hood-photo {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--cream-deep);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1rem;
  }
  .hood-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .hood-card:hover .hood-photo img { transform: scale(1.05); }
  /* Elegant fallback for neighborhoods still awaiting photography. Num + pill
     stay top-aligned like photo cards; the character line sits at the bottom so
     nothing collides with the numeral. */
  .hood-photo--placeholder {
    background:
      radial-gradient(120% 100% at 100% 0%, color-mix(in srgb, var(--gold) 26%, transparent), transparent 60%),
      linear-gradient(150deg, var(--noir-soft), #2b2924 70%);
  }
  .hood-photo-mark {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    max-width: 70%;
    font-family: var(--font-display);
    font-size: 0.98rem;
    line-height: 1.25;
    color: color-mix(in srgb, var(--gold-bright) 88%, #fff);
    text-shadow: 0 1px 6px rgba(0,0,0,0.4);
  }
  .hood-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20,18,15,0.45) 0%, rgba(20,18,15,0) 38%);
    pointer-events: none;
  }
  .hood-num {
    position: relative;
    font-family: var(--font-display);
    font-size: 2.6rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
    line-height: 1;
  }
  .pill { position: relative; background: var(--bg-elevated); box-shadow: 0 2px 8px rgba(0,0,0,0.18); }
  .hood-body { padding: 1.4rem 1.5rem 1.6rem; display: flex; flex-direction: column; gap: 0.7rem; flex-grow: 1; }
  .hood-name { font-size: 1.6rem; }
  .hood-tagline { font-size: 0.92rem; color: var(--ink-soft); flex-grow: 1; }
  .hood-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.6rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
  .hood-range {
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold-deep);
  }
  .arrow-only::after { display: none; }
  .hood-card:hover .arrow { transform: translateX(5px); color: var(--gold-deep); }
</style>
